{
  "mcpServers": {
    "keycloak-admin-automation": {
      "command": "node",
      "args": ["/absolute/path/to/keycloak-mcp-admin-automation/dist/index.js"],
      "env": {
        "KEYCLOAK_BASE_URL": "http://localhost:8080",
        "KEYCLOAK_ADMIN_REALM": "master",
        "KEYCLOAK_TARGET_REALM": "demo",
        "KEYCLOAK_CLIENT_ID": "mcp-admin-automation",
        "KEYCLOAK_CLIENT_SECRET": "replace-me",
        "KEYCLOAK_ALLOWED_REALMS": "demo",
        "KEYCLOAK_ALLOW_WRITE_TOOLS": "false",
        "KEYCLOAK_DEFAULT_DRY_RUN": "true"
      }
    }
  }
}
